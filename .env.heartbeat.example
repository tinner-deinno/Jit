# ═══════════════════════════════════════════════════════════════
# Jit 24/7 Heartbeat Configuration
# 
# Copy to .env and fill in values for your environment
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────
# MDES Ollama Configuration (Required for Ollama-based heartbeat)
# ─────────────────────────────────────────────────────────────
OLLAMA_TOKEN=9e34679b9d60d8b984005ec46508579c
OLLAMA_BASE_URL=https://ollama.mdes-innova.online
OLLAMA_MODEL=gemma4:26b

# ─────────────────────────────────────────────────────────────
# Discord Integration (Optional but recommended)
# ─────────────────────────────────────────────────────────────
# Get webhook from: Discord Server → Settings → Webhooks → New Webhook
# Example: https://discord.com/api/webhooks/1234567890/abcdefghijklmnop
DISCORD_WEBHOOK=

# Optional: Discord channel ID for specific channel notifications
DISCORD_CHANNEL_ID=

# Optional: Discord bot token (if using bot instead of webhook)
DISCORD_TOKEN=

# ─────────────────────────────────────────────────────────────
# Heartbeat Configuration
# ─────────────────────────────────────────────────────────────
# Pulse interval in seconds (default: 900 = 15 minutes)
PULSE_INTERVAL=900

# Max consecutive failures before critical alert
MAX_CONSECUTIVE_FAILURES=3

# ─────────────────────────────────────────────────────────────
# GitHub Configuration (for auto-push)
# ─────────────────────────────────────────────────────────────
# Optional: GitHub token for authenticated pushes (if needed)
GITHUB_TOKEN=

# ─────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────
HEARTBEAT_LOG_DIR=/tmp
DEBUG=false
