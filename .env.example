# MDES Ollama Configuration
# Copy this file to .env and fill in the actual token
# DO NOT commit .env to version control
# DO NOT hardcode tokens in code

OLLAMA_TOKEN=your_mdes_ollama_token_here
OLLAMA_BASE_URL=https://ollama.mdes-innova.online
ORACLE_PORT=47778

# Add other secrets here as needed
# GITHUB_TOKEN=xxx
# SLACK_TOKEN=xxx

# Discord control plane for Hermes → Jit
# DISCORD_TOKEN=your_discord_bot_token_here
# BOT_PREFIX=!อนุ
# JIT_COMMAND_PREFIX=!jit
# JIT_REPORT_CHANNEL_ID=discord_channel_id_for_startup_reports
# JIT_DISCORD_DEV_RECIPIENTS=jit,soma,innova

# Optional repo settings for innova-bot automation
# INNOVA_BOT_REPO=https://github.com/<owner>/innova-bot.git
# INNOVA_BOT_PATH=/workspaces/innova-bot
# INNOVA_BOT_PATH=C:\Users\USER-NT\DEV\innova-bot-template
# INNOVA_BOT_BRIDGE_DIR=/workspaces/innova-bot/.jit-bridge/inbox
# INNOVA_BOT_BRIDGE_URL=http://127.0.0.1:7010/api/jit/discord
# INNOVA_BOT_HEALTH_URL=http://127.0.0.1:7010/mcp/health
# JIT_BODY_BRIDGE_PORT=7011
# JIT_BODY_BRIDGE_HEALTH_URL=http://127.0.0.1:7011/health
# JIT_BODY_EXECUTOR_COMMAND=bash /workspaces/Jit/scripts/discord-dev-executor.sh
# JIT_BODY_EXECUTOR_FORWARD=bash /mnt/c/Users/USER-NT/DEV/innova-bot-template/scripts/dev-dispatch.sh

# Hermes grounded thought loop
# JIT_THOUGHT_LOOP_ENABLED=true
# JIT_THOUGHT_LOOP_CHANNELS=discord_channel_id_1,discord_channel_id_2
# JIT_THOUGHT_LOOP_INTERVAL_MS=300000
# JIT_THOUGHT_LOOP_ACTIVE_WINDOW_MS=900000
# JIT_THOUGHT_LOOP_MIN_MESSAGES=4
# JIT_THOUGHT_LOOP_MIN_PARTICIPANTS=2
