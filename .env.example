# MDES Ollama Configuration
# Copy this file to .env and fill in the actual token
# DO NOT commit .env to version control
# DO NOT hardcode tokens in code

OLLAMA_TOKEN=your_mdes_ollama_token_here
OLLAMA_BASE_URL=https://ollama.mdes-innova.online
ORACLE_PORT=47778

# Bus Security Configuration (JIT-011)
# MANUSAT_BUS_SECRET — Shared HMAC key for message signing (required for auth)
#   Generate with: openssl rand -hex 32
# MANUSAT_STRICT_AUTH — 0=accept unsigned legacy messages, 1=require signature (default)
MANUSAT_BUS_SECRET=your_secret_key_here_min_32_bytes
MANUSAT_STRICT_AUTH=1

# Add other secrets here as needed
# GITHUB_TOKEN=xxx
# SLACK_TOKEN=xxx
# Optional repo settings for innova-bot automation
# INNOVA_BOT_REPO=https://github.com/<owner>/innova-bot.git
# INNOVA_BOT_PATH=/workspaces/innova-bot
