          ],
          "example": "node secure_validator_cli.js enum \"admin\" '[\"user\", \"admin\", \"guest\"]'",
          "response_schema": {
            "status": "string (success|validation_failed|error)",
            "completion_percent": "integer (0 or 100)",
            "data": {
