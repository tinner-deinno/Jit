      "endpoints": [
        {
          "endpoint": "validate",
          "description": "Validate single input with configurable depth and length constraints",
          "method": "command",
          "usage": "validate <input> [options]",
          "parameters": [
            {
              "name": "input",
              "type": "string",
              "required": true,
              "description": "Input string to validate"
            },
            {
              "name": "maxLength",
              "type": "integer",
              "required": false,
              "default": 10000,
              "flag": "--maxLength=N",
              "description": "Maximum allowed input length in characters"
            },
            {
              "name": "maxDepth",
              "type": "integer",
              "required": false,
              "default": 20,
              "flag": "--maxDepth=N",
              "description": "Maximum nesting depth for complex structures"
            },
            {
              "name": "allowNull",
              "type": "boolean",
              "required": false,
              "default": true,
              "flag": "--allowNull=true|false",
              "description": "Whether null values are permitted"
            },
            {
              "name": "sanitize",
              "type": "boolean",
              "required": false,
              "default": true,
              "flag": "--sanitize=true|false",
              "description": "Whether to sanitize dangerous characters/patterns"
            }
          ],
          "example": "node secure_validator_cli.js validate \"SELECT * FROM users\" --maxLength=5000",
          "response_schema": {
            "status": "string (success|validation_failed|error)",
            "completion_percent": "integer (0-100)",
            "data": {
              "input": "string (truncated to 50 chars if longer)",
              "valid": "boolean",
              "errors": "array of error objects",
              "sanitized": "string (cleaned output)"
            },
            "timestamp": "ISO 8601 datetime"
          }
        },
        {
          "endpoint": "batch",
          "description": "Validate multiple inputs as JSON array with summary statistics",
          "method": "command",
          "usage": "batch <json-array> [options]",
          "parameters": [
            {
              "name": "json-array",
              "type": "string (JSON)",
              "required": true,
              "description": "Array of strings to validate: [\"input1\", \"input2\", ...]"
            },
            {
              "name": "maxLength",
              "type": "integer",
              "required": false,
              "default": 10000,
              "flag": "--maxLength=N",
              "description": "Maximum allowed input length per item"
            },
            {
              "name": "maxDepth",
              "type": "integer",
              "required": false,
              "default": 20,
              "flag": "--maxDepth=N",
              "description": "Maximum nesting depth per item"
            },
            {
              "name": "sanitize",
              "type": "boolean",
              "required": false,
              "default": true,
              "flag": "--sanitize=true|false",
              "description": "Whether to sanitize each input"
            }
          ],
          "example": "node secure_validator_cli.js batch '[\"test1\", \"test2\", \"test3\"]'",
          "response_schema": {
            "status": "string (success|partial_failure|error)",
            "completion_percent": "integer (0-100, calculated as valid_count/total_count * 100)",
            "data": {
              "total": "integer (number of inputs)",
              "valid": "integer (number of valid inputs)",
              "invalid": "integer (number of invalid inputs)",
              "results": "array of {input, valid, errors} objects"
            },
            "timestamp": "ISO 8601 datetime"
          }
        },
