      {
        "id": "1",
        "endpoint": "validate",
        "version": "1.2",
        "method": "command",
        "description": "Single input validation with constraints and sanitization",
        "usage": "validate <input> [options]",
        "stability": "stable",
        "parameters": [
          {
            "name": "input",
            "type": "string",
            "required": true,
            "description": "Input string to validate",
            "max_length": 100000,
            "examples": ["SELECT * FROM users", "user@example.com", "192.168.1.1"]
          },
          {
            "name": "maxLength",
            "type": "integer",
            "required": false,
            "default": 10000,
            "flag": "--maxLength=N",
            "min": 1,
            "max": 100000,
            "description": "Maximum allowed input length"
          },
          {
            "name": "maxDepth",
            "type": "integer",
            "required": false,
            "default": 20,
            "flag": "--maxDepth=N",
            "min": 1,
            "max": 100,
            "description": "Maximum nesting depth for structures"
          },
          {
            "name": "allowNull",
            "type": "boolean",
            "required": false,
            "default": true,
            "flag": "--allowNull=true|false",
            "description": "Allow null/empty values"
          },
          {
            "name": "sanitize",
            "type": "boolean",
            "required": false,
            "default": true,
            "flag": "--sanitize=true|false",
            "description": "Sanitize dangerous patterns"
          },
          {
            "name": "strict",
            "type": "boolean",
            "required": false,
            "default": false,
            "flag": "--strict=true|false",
            "description": "Enforce strict validation rules"
          }
        ],
        "response": {
          "status": "string",
          "completion_percent": "integer",
          "data": {
            "input": "string (first 50 chars)",
            "valid": "boolean",
            "length": "integer",
            "errors": "array",
            "sanitized": "string",
            "validation_time_ms": "integer"
          },
          "timestamp": "ISO 8601"
        },
        "examples": [
          {
            "description": "Simple string validation",
            "command": "validate 'Hello World'",
            "output": {
              "status": "success",
              "completion_percent": 100,
              "data": {"input": "Hello World", "valid": true, "errors": []}
            }
          },
          {
