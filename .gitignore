# Environment variables and secrets
# Covers all .env variants in root and subdirectories
.env
.env.*
*.env
!.env.example

# API tokens and credentials (NEVER commit these)
secrets.json
credentials.json
tokens.json

# Encrypted secrets vault (passphrase-protected, but don't commit the vault itself)
.secrets/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Node/Bun dependencies
node_modules/
.bun/

# Python bytecode — never commit compiled artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# Temporary and build files
/tmp/
/build/
*.log
!memory/state/heartbeat.log
*.tmp
*.backup

# OS files
.DS_Store
Thumbs.db

# Local development
.claude/
*.local.json

# Private memory/notes
/private/
/notes/

# Oracle local database (if running locally)
~/.oracle/

# Message bus temporary files (recreated each session)
/tmp/manusat-bus/
/tmp/manusat-shared.json

# Runtime state — local to each node, never commit
/memory/state/innova.state.json
/memory/state/heart.in.json
/memory/state/heart.out.json
/memory/state/context.index.json
/memory/state/jit-presence-report.md

# karn voice transcripts — runtime output, generated by API, not source
/voices/karn-*.md

# Phase 36.5: local durable leaderboard store (JSON mirror is the portable seed)
network/leaderboard.db
network/leaderboard.db-wal
network/leaderboard.db-shm
network/mother-events.jsonl
network/artifacts/
network/breaker-state.json
