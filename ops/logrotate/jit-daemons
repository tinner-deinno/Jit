# Jit Daemon Log Rotation Configuration
# ติดตั้ง: sudo cp /workspaces/Jit/ops/logrotate/jit-daemons /etc/logrotate.d/
# หรือ symlink: sudo ln -s /workspaces/Jit/ops/logrotate/jit-daemons /etc/logrotate.d/jit-daemons

/var/log/jit/*.log {
    daily
    rotate 14
    compress
    delaycompress
    missingok
    notifempty
    create 0640 codespace codespace
    sharedscripts
    postrotate
        # Reload systemd-journald เพื่อรับ log rotation signal (ถ้าใช้ journal)
        systemctl reload systemd-journald 2>/dev/null || true
    endscript
}

