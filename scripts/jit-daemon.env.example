# /etc/jit/jit-daemon.env.example
#
# Copy this file to /etc/jit/jit-daemon.env and fill in real values.
# Permissions MUST be 0640 (root:innova) — never world-readable.
#
#   sudo mkdir -p /etc/jit
#   sudo install -m 0640 -o root -g innova \
#       /workspaces/Jit/scripts/jit-daemon.env.example \
#       /etc/jit/jit-daemon.env
#   sudo -e /etc/jit/jit-daemon.env
#
# !! DO NOT commit this file with real values. It is .gitignored. !!
# !! Real secrets live ONLY in /etc/jit/jit-daemon.env            !!

# ─── Required credentials ────────────────────────────────────────

# MDES Ollama API token (obtain from innova agent setup)
OLLAMA_TOKEN=REPLACE_WITH_REAL_TOKEN

# ─── Optional credentials ────────────────────────────────────────

# Discord webhook URL — leave empty to disable Discord notifications
DISCORD_WEBHOOK=

# GitHub personal access token — leave empty to use SSH key auth
GIT_TOKEN=

# ─── Optional overrides ──────────────────────────────────────────

# Ollama base URL (default: https://ollama.mdes-innova.online)
# OLLAMA_BASE_URL=https://ollama.mdes-innova.online

# Oracle port (default: 47778)
# ORACLE_PORT=47778
